generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  role          String    @default("technician")
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  technician       Technician?
  createdJobs      Job[]           @relation("JobCreatedBy")
  createdEstimates Estimate[]      @relation("EstimateCreatedBy")
  createdInvoices  Invoice[]       @relation("InvoiceCreatedBy")
  calls            Call[]
  notifications    Notification[]
  timeEntries      TimeEntry[]
}

model Customer {
  id             String   @id @default(uuid())
  customerNumber String   @unique
  firstName      String
  lastName       String
  email          String?
  phone          String
  mobilePhone    String?
  type           String   @default("residential")
  companyName    String?
  tags           String?
  source         String?
  notes          String?
  doNotContact   Boolean  @default(false)
  creditLimit    Float?
  balance        Float    @default(0)
  isActive       Boolean  @default(true)
  pricingTierId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  locations         Location[]
  jobs              Job[]
  estimates         Estimate[]
  invoices          Invoice[]
  calls             Call[]
  contacts          Contact[]
  serviceAgreements ServiceAgreement[]
  payments          Payment[]
  equipment         Equipment[]
  purchaseOrders    PurchaseOrder[]
  serializedUnits   SerializedUnit[]
  pricingTier       PricingTier?     @relation(fields: [pricingTierId], references: [id])
}

model Contact {
  id         String   @id @default(uuid())
  customerId String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Location {
  id         String   @id @default(uuid())
  customerId String
  name       String?
  address    String
  city       String
  state      String
  zip        String
  country    String   @default("US")
  lat        Float?
  lng        Float?
  type       String   @default("service")
  notes      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs          Job[]
  equipment     Equipment[]
  installedUnits SerializedUnit[]
}

model Technician {
  id             String    @id @default(uuid())
  userId         String    @unique
  employeeId     String    @unique
  skills         String?
  zones          String?
  vehicleId      String?
  currentLat     Float?
  currentLng     Float?
  lastLocationAt DateTime?
  isAvailable    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  jobs        JobTechnician[]
  timeEntries TimeEntry[]
  vehicle     Vehicle?        @relation(fields: [vehicleId], references: [id])
}

model Vehicle {
  id           String   @id @default(uuid())
  name         String
  make         String?
  model        String?
  year         Int?
  vin          String?
  licensePlate String?
  color        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technicians   Technician[]
  stockLocation StockLocation?
}

model Job {
  id              String    @id @default(uuid())
  jobNumber       String    @unique
  customerId      String
  locationId      String?
  type            String    @default("service")
  status          String    @default("scheduled")
  priority        String    @default("normal")
  summary         String
  description     String?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  duration        Int?
  businessUnit    String?
  campaignId      String?
  callId          String?
  tags            String?
  notes           String?
  techNotes       String?
  completionNotes String?
  createdById     String
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  followUpDate    DateTime?
  totalAmount     Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer    Customer        @relation(fields: [customerId], references: [id])
  location    Location?       @relation(fields: [locationId], references: [id])
  createdBy   User            @relation("JobCreatedBy", fields: [createdById], references: [id])
  technicians          JobTechnician[]
  estimates            Estimate[]
  invoices             Invoice[]
  equipment            Equipment[]
  forms                JobForm[]
  timeEntries          TimeEntry[]
  call                 Call?           @relation(fields: [callId], references: [id])
  purchaseOrders       PurchaseOrder[]
  inventoryTransactions InventoryTransaction[]
  serializedUnits      SerializedUnit[]
}

model JobTechnician {
  id           String    @id @default(uuid())
  jobId        String
  technicianId String
  isLead       Boolean   @default(false)
  status       String    @default("assigned")
  arrivedAt    DateTime?
  departedAt   DateTime?
  createdAt    DateTime  @default(now())

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id])

  @@unique([jobId, technicianId])
}

model Estimate {
  id              String    @id @default(uuid())
  estimateNumber  String    @unique
  customerId      String
  jobId           String?
  status          String    @default("draft")
  title           String
  summary         String?
  validUntil      DateTime?
  subtotal        Float     @default(0)
  discountType    String?
  discountValue   Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  total           Float     @default(0)
  notes           String?
  terms           String?
  sentAt          DateTime?
  viewedAt        DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  signatureUrl    String?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer  Customer           @relation(fields: [customerId], references: [id])
  job       Job?               @relation(fields: [jobId], references: [id])
  createdBy User               @relation("EstimateCreatedBy", fields: [createdById], references: [id])
  lineItems EstimateLineItem[]
  invoice   Invoice?
}

model EstimateLineItem {
  id              String   @id @default(uuid())
  estimateId      String
  type            String   @default("service")
  name            String
  description     String?
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  sortOrder       Int      @default(0)
  pricebookItemId String?
  createdAt       DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  customerId    String
  jobId         String?
  estimateId    String?   @unique
  status        String    @default("draft")
  dueDate       DateTime?
  subtotal      Float     @default(0)
  discountType  String?
  discountValue Float     @default(0)
  taxRate       Float     @default(0)
  taxAmount     Float     @default(0)
  total         Float     @default(0)
  amountPaid    Float     @default(0)
  balance       Float     @default(0)
  notes         String?
  terms         String?
  sentAt        DateTime?
  paidAt        DateTime?
  voidedAt      DateTime?
  voidReason    String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer  Customer          @relation(fields: [customerId], references: [id])
  job       Job?              @relation(fields: [jobId], references: [id])
  estimate  Estimate?         @relation(fields: [estimateId], references: [id])
  createdBy User              @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]
}

model InvoiceLineItem {
  id              String   @id @default(uuid())
  invoiceId       String
  type            String   @default("service")
  name            String
  description     String?
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  sortOrder       Int      @default(0)
  pricebookItemId String?
  createdAt       DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String    @id @default(uuid())
  invoiceId       String
  customerId      String
  amount          Float
  method          String
  status          String    @default("completed")
  referenceNumber String?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  invoice  Invoice  @relation(fields: [invoiceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

model PricebookCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent         PricebookCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       PricebookCategory[] @relation("CategoryHierarchy")
  items          PricebookItem[]
  inventoryItems InventoryItem[]
}

model PricebookItem {
  id               String   @id @default(uuid())
  categoryId       String?
  sku              String?  @unique
  name             String
  description      String?
  type             String   @default("service")
  unitCost         Float    @default(0)
  unitPrice        Float    @default(0)
  unit             String?
  taxable          Boolean  @default(true)
  isActive         Boolean  @default(true)
  imageUrl         String?
  warrantyMonths   Int?
  vendorPartNumber String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category           PricebookCategory?       @relation(fields: [categoryId], references: [id])
  inventoryItems     InventoryItem[]
  quickbooksMappings QuickBooksItemMapping[]
  tierOverrides      PricingTierOverride[]
}

// ─── Customer pricing tiers ───────────────────────────────────────────────
// A tier applies a blanket discount to every pricebook item for the customers
// assigned to it, with optional per-item overrides (e.g. "10% off everything,
// but this one part is always $45 flat"). Resolution order: item-specific
// override, then the tier's blanket discount, then the catalog price as-is.

model PricingTier {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  discountType  String   @default("percentage") // lookup: discountType
  discountValue Float    @default(0)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers Customer[]
  overrides PricingTierOverride[]
}

model PricingTierOverride {
  id              String   @id @default(uuid())
  pricingTierId   String
  pricebookItemId String
  overrideType    String   // lookup: pricingOverrideType (percentage|fixed|fixed_price)
  overrideValue   Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pricingTier   PricingTier   @relation(fields: [pricingTierId], references: [id], onDelete: Cascade)
  pricebookItem PricebookItem @relation(fields: [pricebookItemId], references: [id], onDelete: Cascade)

  @@unique([pricingTierId, pricebookItemId])
}

// ─── QuickBooks Desktop sync (Web Connector / qbXML) ────────────────────────
// One-directional: PulseService is the system of record. QuickBooks Desktop has
// no server of its own, so QuickBooks Web Connector (a small app that runs next
// to QuickBooks Desktop) POLLS our SOAP endpoint on a timer and pulls down
// whatever is queued, translated into qbXML. Nothing here is pushed by us.

model QuickBooksSettings {
  id                       String    @id @default(uuid())
  isEnabled                Boolean   @default(false)
  companyFileName          String?   // blank = whatever company file QB has open
  webConnectorUsername     String    @default("pulseservice")
  webConnectorPasswordHash String?
  // Placeholder mapping data until the bookkeeper provides real QuickBooks Item
  // names — editable from Settings → QuickBooks without any code change.
  salesTaxItemName         String    @default("PLACEHOLDER - Sales Tax")
  depositToAccountName     String?   // null = Undeposited Funds (QB default)
  appId                    String    @default("PulseServiceQB")
  appName                  String    @default("PulseService QuickBooks Sync")
  // Stable GUIDs embedded in the generated .qwc connector file; generated once
  // on first download and kept stable so re-downloading doesn't require the
  // user to re-add the connector in Web Connector.
  ownerId                  String?
  qbwcFileId               String?
  lastSyncStartedAt        DateTime?
  lastSyncCompletedAt      DateTime?
  updatedAt                DateTime  @updatedAt
}

// Identity map: which QuickBooks List/Txn ID a PulseService record became once
// synced, plus the EditSequence QuickBooks requires for any subsequent update.
model QuickBooksMapping {
  id           String   @id @default(uuid())
  entityType   String   // lookup: quickbooksEntityType
  entityId     String
  quickbooksId String   // ListID (Customer) or TxnID (Invoice/Payment)
  editSequence String?
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([quickbooksId])
}

// Outbound work queue. Rows are enqueued the moment a record changes in
// PulseService (real-time from our side); QuickBooks Web Connector drains them
// at whatever interval it's configured to poll (a Desktop/Web-Connector
// limitation, not ours — see docs/quickbooks-sync.md).
model QuickBooksSyncQueue {
  id            String    @id @default(uuid())
  entityType    String    // lookup: quickbooksEntityType
  entityId      String
  operation     String    // lookup: quickbooksSyncOperation
  status        String    @default("pending") // lookup: quickbooksSyncStatus
  requestId     String?   // correlates to the qbXML requestID while in flight
  attempts      Int       @default(0)
  lastError     String?
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([entityType, entityId])
}

// Maps a PulseService pricebook item (or a whole line-item category, as a
// fallback) to the QuickBooks Item name that invoice lines should reference.
// Seeded with obvious placeholders; Finance/the bookkeeper edit these in place.
model QuickBooksItemMapping {
  id                 String   @id @default(uuid())
  lineItemType       String?  // fallback by category, e.g. "service" | "part"
  pricebookItemId    String?  // specific-item override
  quickbooksItemName String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  pricebookItem PricebookItem? @relation(fields: [pricebookItemId], references: [id])

  @@index([lineItemType])
  @@index([pricebookItemId])
}

// ─── Inventory & Purchasing ────────────────────────────────────────────────────────────────
// Multi-location model: stock lives in InventoryStock keyed by (item, location).
// A StockLocation is either the main warehouse or a truck (a Vehicle assigned to
// a technician). Costing is perpetual weighted-average, recomputed at receipt.

model Supplier {
  id             String   @id @default(uuid())
  supplierNumber String   @unique
  name           String
  contactName    String?
  email          String?
  phone          String?
  website        String?
  address1       String?
  address2       String?
  city           String?
  state          String?
  zip            String?
  country        String?  @default("USA")
  paymentTerms   String?
  taxId          String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items           InventoryItemSupplier[]
  purchaseOrders  PurchaseOrder[]
  defaultForItems InventoryItem[]         @relation("ItemDefaultSupplier")
}

model StockLocation {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  type      String   @default("warehouse") // lookup: stockLocationType
  vehicleId String?  @unique // set when type = truck
  address   String?
  isDefault Boolean  @default(false) // the main warehouse
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle         Vehicle?               @relation(fields: [vehicleId], references: [id])
  stock           InventoryStock[]
  transactions    InventoryTransaction[]
  receipts        POLineReceipt[]
  shipToPOs       PurchaseOrder[]        @relation("PO_ShipTo")
  serializedUnits SerializedUnit[]

  @@index([type])
  @@index([code])
}

model InventoryItem {
  id                String   @id @default(uuid())
  sku               String   @unique
  name              String
  description       String?
  pricebookItemId   String?
  categoryId        String?
  unit              String   @default("each")
  unitCost          Decimal  @default(0) @db.Decimal(12, 4) // perpetual weighted-average cost
  defaultSupplierId String?
  minQuantity       Decimal  @default(0) @db.Decimal(12, 2)
  maxQuantity       Decimal  @default(0) @db.Decimal(12, 2)
  reorderPoint      Decimal  @default(0) @db.Decimal(12, 2)
  reorderQuantity   Decimal  @default(0) @db.Decimal(12, 2)
  leadTimeDays      Int?
  isSerialized      Boolean  @default(false)
  isStockItem       Boolean  @default(true)
  isActive          Boolean  @default(true)
  isArchived        Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pricebookItem   PricebookItem?             @relation(fields: [pricebookItemId], references: [id])
  category        PricebookCategory?         @relation(fields: [categoryId], references: [id])
  defaultSupplier Supplier?                  @relation("ItemDefaultSupplier", fields: [defaultSupplierId], references: [id])
  stock           InventoryStock[]
  transactions    InventoryTransaction[]
  suppliers       InventoryItemSupplier[]
  poLines         POLine[]
  serializedUnits SerializedUnit[]
  costHistory     InventoryItemCostHistory[]

  @@index([sku])
  @@index([isActive, isArchived])
  @@index([defaultSupplierId])
}

model InventoryStock {
  id               String    @id @default(uuid())
  inventoryItemId  String
  stockLocationId  String
  quantityOnHand   Decimal   @default(0) @db.Decimal(12, 2)
  quantityReserved Decimal   @default(0) @db.Decimal(12, 2)
  lastCountDate    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@unique([inventoryItemId, stockLocationId])
  @@index([stockLocationId])
}

model InventoryItemSupplier {
  id              String    @id @default(uuid())
  inventoryItemId String
  supplierId      String
  supplierSku     String?
  unitCost        Decimal   @db.Decimal(12, 4)
  leadTimeDays    Int?
  minimumOrderQty Decimal?  @db.Decimal(12, 2)
  isPrimary       Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastOrderDate   DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier      Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, supplierId])
  @@index([supplierId])
}

model InventoryItemCostHistory {
  id              String   @id @default(uuid())
  inventoryItemId String
  oldUnitCost     Decimal  @db.Decimal(12, 4)
  newUnitCost     Decimal  @db.Decimal(12, 4)
  changeSource    String   // lookup: costChangeSource
  quantityOnHand  Decimal? @db.Decimal(12, 2)
  receiptQuantity Decimal? @db.Decimal(12, 2)
  receiptUnitCost Decimal? @db.Decimal(12, 4)
  supplierId      String?
  referenceType   String?
  referenceId     String?
  notes           String?
  performedBy     String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId, createdAt])
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  inventoryItemId String
  stockLocationId String
  type            String   // lookup: inventoryTransactionType
  quantity        Decimal  @db.Decimal(12, 2)
  unitCost        Decimal? @db.Decimal(12, 4)
  quantityBefore  Decimal? @db.Decimal(12, 2)
  quantityAfter   Decimal? @db.Decimal(12, 2)
  referenceType   String?
  referenceId     String?
  referenceNumber String?
  jobId           String?
  notes           String?
  performedBy     String?  // userId (audit-style, no hard FK)
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())

  // reversal linkage — transactions are append-only and reversed, never deleted
  isReversed     Boolean   @default(false)
  reversalOfId   String?   @unique
  reversalReason String?
  reversedAt     DateTime?

  inventoryItem InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation         @relation(fields: [stockLocationId], references: [id])
  job           Job?                  @relation(fields: [jobId], references: [id])
  reversalOf    InventoryTransaction? @relation("TxnReversal", fields: [reversalOfId], references: [id])
  reversal      InventoryTransaction? @relation("TxnReversal")

  @@index([inventoryItemId, transactionDate])
  @@index([referenceType, referenceId])
  @@index([stockLocationId])
  @@index([type])
}

model PurchaseOrder {
  id               String    @id @default(uuid())
  poNumber         String    @unique
  supplierId       String
  status           String    @default("draft") // lookup: poStatus
  shipToLocationId String?
  jobId            String?
  customerId       String?
  orderDate        DateTime  @default(now())
  expectedDate     DateTime?
  receivedDate     DateTime?
  sentAt           DateTime?
  approvedAt       DateTime?
  closedAt         DateTime?
  subtotal         Decimal   @default(0) @db.Decimal(14, 4)
  taxAmount        Decimal   @default(0) @db.Decimal(14, 4)
  shippingCost     Decimal   @default(0) @db.Decimal(14, 4)
  totalAmount      Decimal   @default(0) @db.Decimal(14, 4)
  deliveryTerms    String?
  notes            String?
  cancelledReason  String?
  cancelledAt      DateTime?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  shipToLocation StockLocation? @relation("PO_ShipTo", fields: [shipToLocationId], references: [id])
  job            Job?           @relation(fields: [jobId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id])
  lines          POLine[]

  @@index([status, orderDate])
  @@index([supplierId])
  @@index([jobId])
}

model POLine {
  id               String    @id @default(uuid())
  purchaseOrderId  String
  inventoryItemId  String?
  lineType         String    @default("inventory") // lookup: poLineType
  lineNumber       Int       @default(0)
  description      String
  quantity         Decimal   @db.Decimal(12, 2)
  unitPrice        Decimal   @db.Decimal(14, 4)
  totalPrice       Decimal   @db.Decimal(14, 4)
  receivedQuantity Decimal   @default(0) @db.Decimal(12, 2) // denormalized cache; self-healed from receipts
  lineStatus       String    @default("open") // lookup: poLineStatus
  deliveryDate     DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  receipts      POLineReceipt[]

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model POLineReceipt {
  id                String   @id @default(uuid())
  poLineId          String
  receiptNumber     String   @unique
  quantityReceived  Decimal  @db.Decimal(12, 2)
  unitCost          Decimal  @db.Decimal(14, 4)
  totalCost         Decimal  @db.Decimal(14, 4)
  stockLocationId   String   // the truck/warehouse the goods were received into
  receivedById      String?
  receivedAt        DateTime @default(now())
  status            String   @default("active") // lookup: receiptStatus
  documentNumber    String?  // packing slip / receiving doc
  serialNumbers     String[] @default([])
  lotNumber         String?
  notes             String?
  isReturn          Boolean  @default(false)
  originalReceiptId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  poLine          POLine           @relation(fields: [poLineId], references: [id], onDelete: Cascade)
  stockLocation   StockLocation    @relation(fields: [stockLocationId], references: [id])
  originalReceipt POLineReceipt?   @relation("ReceiptReturns", fields: [originalReceiptId], references: [id])
  returnReceipts  POLineReceipt[]  @relation("ReceiptReturns")
  serializedUnits SerializedUnit[]

  @@index([poLineId])
  @@index([stockLocationId])
}

model SerializedUnit {
  id                  String    @id @default(uuid())
  serialNumber        String
  inventoryItemId     String
  status              String    @default("in_stock") // lookup: serializedUnitStatus
  stockLocationId     String?
  sourceReceiptId     String?
  purchaseCost        Decimal?  @db.Decimal(14, 4)
  installedCustomerId String?
  installedLocationId String?
  installedJobId      String?
  equipmentId         String?   @unique
  installedAt         DateTime?
  warrantyMonths      Int?
  warrantyExpiresAt   DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  inventoryItem     InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  stockLocation     StockLocation? @relation(fields: [stockLocationId], references: [id])
  sourceReceipt     POLineReceipt? @relation(fields: [sourceReceiptId], references: [id])
  installedCustomer Customer?      @relation(fields: [installedCustomerId], references: [id])
  installedLocation Location?      @relation(fields: [installedLocationId], references: [id])
  installedJob      Job?           @relation(fields: [installedJobId], references: [id])
  equipment         Equipment?     @relation(fields: [equipmentId], references: [id])

  @@unique([inventoryItemId, serialNumber])
  @@index([status])
  @@index([stockLocationId])
  @@index([equipmentId])
}

model ServiceAgreement {
  id               String    @id @default(uuid())
  agreementNumber  String    @unique
  customerId       String
  name             String
  status           String    @default("active")
  startDate        DateTime
  endDate          DateTime
  billingFrequency String
  amount           Float
  autoRenew        Boolean   @default(false)
  terms            String?
  notes            String?
  nextBillingDate  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  customer Customer         @relation(fields: [customerId], references: [id])
  visits   AgreementVisit[]
}

model AgreementVisit {
  id            String    @id @default(uuid())
  agreementId   String
  name          String
  scheduledDate DateTime?
  completedDate DateTime?
  jobId         String?
  status        String    @default("pending")
  notes         String?

  agreement ServiceAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
}

model Equipment {
  id             String    @id @default(uuid())
  customerId     String?
  locationId     String?
  jobId          String?
  name           String
  type           String?
  manufacturer   String?
  model          String?
  serialNumber   String?
  installDate    DateTime?
  warrantyExpiry DateTime?
  condition      String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer       Customer?       @relation(fields: [customerId], references: [id])
  location       Location?       @relation(fields: [locationId], references: [id])
  job            Job?            @relation(fields: [jobId], references: [id])
  serializedUnit SerializedUnit?
}

model Call {
  id           String   @id @default(uuid())
  customerId   String?
  direction    String
  status       String
  fromNumber   String?
  toNumber     String?
  duration     Int?
  recordingUrl String?
  reason       String?
  campaignId   String?
  handledById  String?
  notes        String?
  createdAt    DateTime @default(now())

  customer  Customer? @relation(fields: [customerId], references: [id])
  handledBy User?     @relation(fields: [handledById], references: [id])
  jobs      Job[]
}

model Campaign {
  id             String    @id @default(uuid())
  name           String
  type           String
  status         String    @default("active")
  budget         Float?
  startDate      DateTime?
  endDate        DateTime?
  trackingNumber String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model JobForm {
  id          String    @id @default(uuid())
  jobId       String
  name        String
  formData    String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id           String    @id @default(uuid())
  technicianId String?
  userId       String
  jobId        String?
  type         String    @default("work")
  startTime    DateTime
  endTime      DateTime?
  duration     Int?
  notes        String?
  createdAt    DateTime  @default(now())

  technician Technician? @relation(fields: [technicianId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  job        Job?        @relation(fields: [jobId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanySettings {
  id                 String   @id @default(uuid())
  name               String   @default("PulseService")
  logo               String?
  address            String?
  city               String?
  state              String?
  zip                String?
  phone              String?
  email              String?
  website            String?
  taxRate            Float    @default(0.085)
  currency           String   @default("USD")
  timezone           String   @default("America/New_York")
  invoiceTerms       String?
  estimateTerms      String?
  jobPrefix          String   @default("JOB")
  invoicePrefix      String   @default("INV")
  estimatePrefix     String   @default("EST")
  customerPrefix     String   @default("CUST")
  supplierPrefix     String   @default("SUP")
  poPrefix           String   @default("PO")
  receiptPrefix      String   @default("RCPT")
  nextJobNumber      Int      @default(1001)
  nextInvoiceNumber  Int      @default(1001)
  nextEstimateNumber Int      @default(1001)
  nextCustomerNumber Int      @default(1001)
  nextSupplierNumber Int      @default(1001)
  nextPoNumber       Int      @default(1001)
  nextReceiptNumber  Int      @default(1001)
  updatedAt          DateTime @updatedAt
}

model BusinessUnit {
  id        String   @id @default(uuid())
  name      String
  type      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Zone {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Polymorphic file/image store. Binary data is kept in Postgres (bytea) so that
// both the web (PC) and mobile clients read/write attachments through the same
// authenticated API with no shared filesystem. `entityType`/`entityId` link an
// attachment to any record (job, estimate, invoice, inventory item, customer).
model Attachment {
  id           String   @id @default(uuid())
  entityType   String
  entityId     String
  filename     String
  mimeType     String
  size         Int
  data         Bytes
  caption      String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
}

// Web Push (VAPID) browser subscriptions, one row per device/browser a user has
// granted notification permission on. Pushes are sent to every row for a user.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Templates that spawn jobs on a repeating schedule (e.g. quarterly maintenance).
// Plain id references (no relations) so this stays a self-contained addition;
// the controller validates the customer/location exist at generation time.
model RecurringJob {
  id          String    @id @default(uuid())
  customerId  String
  locationId  String?
  summary     String
  description String?
  type        String    @default("service")
  priority    String    @default("normal")
  frequency   String    @default("monthly")
  interval    Int       @default(1)
  nextRunDate DateTime
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([nextRunDate])
}

// DB-driven single source of truth for enumerated values (statuses, types,
// roles, priorities, etc.). Seeded from src/constants/lookups.js and served to
// the frontend via GET /api/v1/metadata.
model Lookup {
  id        String   @id @default(uuid())
  category  String
  value     String
  label     String
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value])
  @@index([category])
}

// Maps a role (see Lookup category "userRole") to the permission keys it grants.
// Seeded from src/constants/permissions.js; editable by admins at runtime.
model RolePermission {
  id         String   @id @default(uuid())
  role       String
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}

// Append-only trail of mutating API actions, written automatically by the audit
// middleware. Used by the Settings → Activity Log viewer.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String?
  userRole   String?
  action     String
  method     String
  path       String
  entity     String?
  entityId   String?
  statusCode Int
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
  @@index([userId])
}
