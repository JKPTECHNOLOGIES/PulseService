# Normalize line endings across platforms
* text=auto

# Shell scripts must always use LF, even on Windows checkouts,
# so they run correctly inside Linux containers.
*.sh text eol=lf

# Ensure web/source files are treated as text
*.js text
*.ts text
*.tsx text
*.json text
*.css text
*.html text
*.md text
*.prisma text
Dockerfile text
nginx.conf text
