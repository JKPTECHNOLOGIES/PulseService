// Prisma Schema - Repairable Items & Direct Issues


enum RepairableEventType {
  CREATED
  STATUS_CHANGED
  CONDITION_CHANGED
  ASSIGNED_TO_EQUIPMENT
  REMOVED_FROM_EQUIPMENT
  TRANSFERRED_EQUIPMENT
  LOCATION_CHANGED
  REPAIR_INITIATED
  REPAIR_WORK_ORDER_CREATED
  REPAIR_REQUISITION_CREATED
  REPAIR_STARTED
  REPAIR_COMPLETED
  RETURNED_TO_INVENTORY
  DIRECT_ISSUED
  DIRECT_ISSUE_RETURNED
  SCRAPPED
  NOTES_UPDATED
  SWAPPED
  ADDED_TO_ASSEMBLY
  REMOVED_FROM_ASSEMBLY
}


model RepairableItem {
  id                  String                  @id @default(uuid())
  inventoryItemId     String
  serialNumber        String                  @unique
  condition           RepairableCondition
  status              RepairableStatus        @default(AVAILABLE)
  currentLocation     String?
  equipmentId         String?
  departmentId        String?                 @map("department_id")
  accountCodeId       String?                 @map("account_code_id")
  purchaseDate        DateTime?
  purchaseCost        Decimal?                @db.Decimal(12, 2)
  warrantyExpiry      DateTime?
  lastRepairDate      DateTime?
  totalRepairCost     Decimal                 @default(0) @db.Decimal(12, 2)
  repairCount         Int                     @default(0)
  notes               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           String
  lastModifiedBy      String?
  isAutoGenerated     Boolean                 @default(false)
  sourceDirectIssueId String?                 @unique
  // The PO line receipt that auto-created this serial (one receipt → many serials).
  // Lets receipt reversal remove exactly the serials it created (no orphans).
  sourcePOLineReceiptId String?
  autoGenQuantity     Decimal?                @db.Decimal(10, 2)
  // Assembly tracking — points to the parent assembly serial this component currently lives inside
  parentAssemblyId    String?
  // Self-referential assembly relations
  parentAssembly      RepairableItem?         @relation("AssemblyComponents", fields: [parentAssemblyId], references: [id])
  childComponents     RepairableItem[]        @relation("AssemblyComponents")
  equipment           Equipment?              @relation("RepairableItem_equipment", fields: [equipmentId], references: [id])
  department          Department?             @relation("RepairableItemDepartment", fields: [departmentId], references: [id])
  accountCode         AccountCode?            @relation("RepairableItemAccountCode", fields: [accountCodeId], references: [id])
  sourceDirectIssue   DirectIssue?            @relation("AutoGeneratedSerial", fields: [sourceDirectIssueId], references: [id])
  sourcePOLineReceipt POLineReceipt?          @relation("RepairableItem_sourceReceipt", fields: [sourcePOLineReceiptId], references: [id])
  requisitions        Requisition[]
  // REMOVED: workOrders          WorkOrder[]  // This was causing schema inconsistency
  // The relationship is one-to-many: WorkOrder -> RepairableItem (via repairableItemId field)
  // A repairable item can be referenced by multiple work orders, but the FK is on WorkOrder side
  repairWorkOrders    WorkOrder[] // Reverse relation for work orders that reference this repairable item
  repairHistories     RepairHistory[]
  poLines             POLine[]                @relation("POLine_repairableItem")
  // Replacement PO lines created (via "scrap & replace") to supersede THIS serial
  // after it was scrapped from a PO.
  replacementPOLines  POLine[]                @relation("POLine_replacesRepairable")
  inventoryItem       InventoryItem           @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  history             RepairableItemHistory[]

  @@index([inventoryItemId])
  @@index([serialNumber])
  @@index([condition])
  @@index([status])
  @@index([currentLocation])
  @@index([equipmentId])
  @@index([departmentId])
  @@index([accountCodeId])
  @@index([createdBy])
  @@index([lastModifiedBy])
  @@index([isAutoGenerated])
  @@index([sourceDirectIssueId])
  @@index([sourcePOLineReceiptId])
  @@index([parentAssemblyId])
  @@map("repairable_items")
}


model RepairableItemHistory {
  id                      String               @id @default(uuid())
  repairableItemId        String
  eventType               RepairableEventType
  eventDate               DateTime             @default(now())
  performedBy             String
  performedByName         String
  previousStatus          RepairableStatus?
  newStatus               RepairableStatus?
  previousCondition       RepairableCondition?
  newCondition            RepairableCondition?
  previousLocation        String?
  newLocation             String?
  previousEquipmentId     String?
  newEquipmentId          String?
  equipmentTag            String?
  workOrderId             String?
  workOrderNumber         String?
  requisitionId           String?
  requisitionNumber       String?
  directIssueId           String?
  directIssueNumber       String?
  repairHistoryId         String?
  replacementSerialNumber String?
  // Assembly event fields — populated for ADDED_TO_ASSEMBLY / REMOVED_FROM_ASSEMBLY events
  assemblyId              String?   // The parent assembly RepairableItem.id
  assemblySerial          String?   // The parent assembly serial number (human-readable)
  notes                   String?
  metadata                Json?
  createdAt               DateTime             @default(now())
  repairableItem          RepairableItem       @relation(fields: [repairableItemId], references: [id], onDelete: Cascade)

  @@index([repairableItemId])
  @@index([eventType])
  @@index([eventDate])
  @@index([performedBy])
  @@index([newStatus])
  @@index([newEquipmentId])
  @@index([workOrderId])
  @@index([requisitionId])
  @@index([directIssueId])
  @@index([assemblyId])
  @@map("repairable_item_history")
}


model RepairHistory {
  id                 String               @id @default(uuid())
  repairableItemId   String
  repairType         RepairType
  repairStatus       RepairStatus         @default(INITIATED)
  workOrderId        String?
  requisitionId      String?
  supplierId         String?
  initiatedDate      DateTime             @default(now())
  initiatedBy        String
  scheduledStartDate DateTime?
  actualStartDate    DateTime?
  completedDate      DateTime?
  returnedDate       DateTime?
  estimatedCost      Decimal?             @db.Decimal(12, 2)
  actualCost         Decimal?             @db.Decimal(12, 2)
  problemDescription String
  repairDescription  String?
  partsReplaced      Json?
  technicianNotes    String?
  conditionBefore    RepairableCondition
  conditionAfter     RepairableCondition?
  warrantyRepair     Boolean              @default(false)
  downtime           Decimal?             @db.Decimal(8, 2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  repairableItem     RepairableItem       @relation(fields: [repairableItemId], references: [id], onDelete: Cascade)
  requisition        Requisition?         @relation(fields: [requisitionId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  workOrder          WorkOrder?           @relation(fields: [workOrderId], references: [id])

  @@index([repairableItemId])
  @@index([repairType])
  @@index([repairStatus])
  @@index([workOrderId])
  @@index([requisitionId])
  @@index([supplierId])
  @@index([initiatedDate])
  @@index([completedDate])
  @@index([initiatedBy])
  @@map("repair_histories")
}


model DirectIssue {
  id                  String              @id @default(uuid())
  issueNumber         String              @unique
  inventoryItemId     String
  storeId             String? // Made optional for serialized items
  quantity            Decimal             @db.Decimal(10, 2)
  serialNumber        String?
  unitCost            Decimal             @db.Decimal(12, 2)
  totalCost           Decimal             @db.Decimal(12, 2)
  departmentId        String?
  accountCodeId       String?
  areaId              String?
  projectId           String?             // Project to charge — budget is consumed from ProjectBudget (priority 1)
  workOrderId         String?
  budgetPeriodId      String?
  issuedBy            String
  issuedByName        String
  issuedAt            DateTime            @default(now())
  purpose             String?
  notes               String?
  quantityReturned    Decimal             @default(0) @db.Decimal(10, 2)
  status              DirectIssueStatus   @default(ISSUED)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  bin                 String              @default("MAIN")
  // NEW: When issued to a PM work order covering multiple equipment,
  // this field records WHICH specific equipment the part was consumed by.
  pmEquipmentId       String?
  returns             DirectIssueReturn[]
  autoGeneratedSerial RepairableItem?     @relation("AutoGeneratedSerial")
  // Reverse relation: repair WOs that were auto-created because of this direct issue.
  // Normally at most one, but modelled as an array for schema correctness.
  repairWorkOrdersCreated WorkOrder[]     @relation("RepairWO_sourceDirectIssue")
  accountCode         AccountCode?        @relation(fields: [accountCodeId], references: [id])
  area                Location?           @relation("DirectIssue_budgetArea", fields: [areaId], references: [id])
  budgetPeriod        BudgetPeriod?       @relation(fields: [budgetPeriodId], references: [id])
  department          Department?         @relation(fields: [departmentId], references: [id])
  inventoryItem       InventoryItem       @relation(fields: [inventoryItemId], references: [id])
  issuer              User                @relation("DirectIssue_issuer", fields: [issuedBy], references: [id])
  store               Store?              @relation(fields: [storeId], references: [id])
  workOrder           WorkOrder?          @relation("DirectIssue_workOrder", fields: [workOrderId], references: [id])
  pmEquipment         Equipment?          @relation("DirectIssueEquipment", fields: [pmEquipmentId], references: [id])
  project             Project?            @relation("DirectIssue_project", fields: [projectId], references: [id])

  @@index([issueNumber])
  @@index([inventoryItemId])
  @@index([storeId])
  @@index([bin])
  @@index([serialNumber])
  @@index([departmentId])
  @@index([accountCodeId])
  @@index([areaId])
  @@index([projectId])
  @@index([workOrderId])
  @@index([budgetPeriodId])
  @@index([issuedBy])
  @@index([issuedAt])
  @@index([status])
  @@index([pmEquipmentId])
  @@map("direct_issues")
}


model DirectIssueReturn {
  id             String          @id @default(uuid())
  directIssueId  String
  returnNumber   String          @unique
  quantity       Decimal         @db.Decimal(10, 2)
  reason         String?
  condition      ReturnCondition @default(GOOD)
  returnedBy     String
  returnedByName String
  returnedAt     DateTime        @default(now())
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  returnToBin    String          @default("MAIN")
  directIssue    DirectIssue     @relation(fields: [directIssueId], references: [id], onDelete: Cascade)
  returner       User            @relation("DirectIssueReturn_returner", fields: [returnedBy], references: [id])

  @@index([directIssueId])
  @@index([returnNumber])
  @@index([returnedBy])
  @@index([returnedAt])
  @@map("direct_issue_returns")
}


enum RepairableCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  FAILED
  BEYOND_REPAIR
}


enum RepairableStatus {
  AVAILABLE
  IN_USE
  // Serial was assigned to a repair WO but the repair path (internal/external/scrap)
  // has not been chosen yet.  Set when IM links a broken serial to the repair WO.
  // Transitions to IN_REPAIR_INTERNAL, IN_REPAIR_EXTERNAL, or SCRAPPED once a path
  // is chosen.  Without this value the code would have to infer "awaiting decision"
  // from RepairHistory absence — which is not DB-driven.
  AWAITING_REPAIR_EVALUATION
  IN_REPAIR_INTERNAL
  IN_REPAIR_EXTERNAL
  AWAITING_PARTS
  REPAIR_COMPLETE
  RETIRED
  SCRAPPED
}


enum RepairType {
  INSIDE
  OUTSIDE
}


enum RepairStatus {
  // Repair WO auto-created from DI; broken serial not yet assigned to it.
  // Recorded on the RepairHistory row so the repair_histories table is the
  // authoritative audit trail for every phase — not just the WO status field.
  AWAITING_SERIAL_ASSIGNMENT
  INITIATED
  WORK_ORDER_CREATED
  REQUISITION_CREATED
  IN_PROGRESS
  AWAITING_PARTS
  // Part physically shipped to external vendor.
  SENT_TO_VENDOR
  // Part received back from vendor; not yet returned to inventory.
  RECEIVED_FROM_VENDOR
  COMPLETED
  RETURNED
  CANCELLED
  // Vendor could not repair the part; it was written off / scrapped from the PO.
  // Terminal state, parallel to CANCELLED but specific to the scrap disposition.
  SCRAPPED
}


enum DirectIssueStatus {
  ISSUED
  PARTIALLY_RETURNED
  FULLY_RETURNED
  CANCELLED
  REVERSED
}


// ─── Assembly BOM (auto-learned) ─────────────────────────────────────────────
//
// Records WHICH component types typically appear inside a given assembly type.
// Rows are created/updated automatically whenever a Direct Issue is made to a
// Work Order that is linked to an assembly serial (RepairableItem.parentAssemblyId
// is set on the issued serial, OR the WO's repairableItemId belongs to an assembly).
//
// typicalQuantity is auto-populated from the first occurrence and can be manually
// overridden by an Inventory Manager (isManualOverride = true prevents auto-update).
// occurrenceCount accumulates every time the component is issued to that assembly
// type across ANY repair job — this is how the BOM "learns" typical quantities.
model RepairableAssemblyBOM {
  id               String        @id @default(uuid())
  // The assembly InventoryItem type (e.g. "Pump, 100HP" SKU)
  assemblyItemId   String
  // The component InventoryItem type (e.g. "Mechanical Seal Kit" SKU)
  componentItemId  String
  // Auto-populated typical quantity; can be manually overridden
  typicalQuantity  Decimal       @default(1) @db.Decimal(10, 2)
  // How many times this component has been issued across all repair jobs for this assembly type
  occurrenceCount  Int           @default(1)
  // When this component was last issued to this assembly type
  lastSeenAt       DateTime      @default(now())
  // True when a user has manually set typicalQuantity — prevents auto-update from overwriting it
  isManualOverride Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  assemblyItem     InventoryItem @relation("AssemblyBOM_assemblyItem",   fields: [assemblyItemId],  references: [id])
  componentItem    InventoryItem @relation("AssemblyBOM_componentItem",  fields: [componentItemId], references: [id])

  // Each (assembly type, component type) pair is unique — upsert on this pair
  @@unique([assemblyItemId, componentItemId])
  @@index([assemblyItemId])
  @@index([componentItemId])
  @@map("repairable_assembly_bom")
}
