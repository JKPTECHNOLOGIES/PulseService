// Prisma Schema - Suppliers & Rental Equipment

// Standalone list of payment terms that can be managed from the
// Supplier Settings page. These terms are used to power the autocomplete
// combobox on supplier edit forms and appear alongside terms already
// stored on individual supplier records.
model SupplierPaymentTerm {
  id        String   @id @default(uuid())
  term      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("supplier_payment_terms")
}


model Supplier {
  id                 String  @id @default(uuid())
  name               String  @unique
  code               String? @unique
  internalVendorCode String? @unique // Auto-generated vendor code for finance (starts at 12000)

  // ── NAV vendor sync tracking ──────────────────────────────
  navVendorSyncedAt     DateTime? @map("navVendorSyncedAt")
  navVendorSyncedBy     String?   @map("navVendorSyncedBy") @db.VarChar(100)
  navVendorSyncVersion  Int       @default(0) @map("navVendorSyncVersion")

  isSupplier         Boolean @default(true)
  isContractor       Boolean @default(false)
  contactPerson      String?
  email              String?
  phone              String?
  fax                String?
  website            String?

  // Billing Address
  billingAddress  String?
  billingAddress2 String?
  billingCity     String?
  billingState    String?
  billingZip      String?
  billingCountry  String? @default("USA")

  // Shipping Address
  shippingAddress  String?
  shippingAddress2 String?
  shippingCity     String?
  shippingState    String?
  shippingZip      String?
  shippingCountry  String? @default("USA")

  // Remittance Address
  remittanceAddress  String?
  remittanceAddress2 String?
  remittanceCity     String?
  remittanceState    String?
  remittanceZip      String?
  remittanceCountry  String? @default("USA")

  // Financial Information
  taxId           String?
  ein             String?
  paymentTerms    String?
  paymentMethod   String?
  creditLimit     Decimal? @db.Decimal(12, 2)
  creditTermsDays Int?
  discountPercent Decimal? @db.Decimal(5, 2)

  // Performance & Ratings
  rating             Int?
  onTimeDeliveryRate Decimal? @db.Decimal(5, 2)
  qualityRating      Decimal? @db.Decimal(5, 2)

  // Operational
  leadTimeDays       Int?
  minimumOrderAmount Decimal? @db.Decimal(12, 2)
  shippingMethod     String?
  accountNumber      String?
  notes              String?
  isActive           Boolean  @default(true)
  defaultRate        Decimal? @db.Decimal(10, 2)
  rateUnit           String?
  parentSupplierId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  inventoryItems         InventoryItem[]
  invoices               Invoice[]
  purchaseOrders         PurchaseOrder[]
  rentalEquipment        RentalEquipment[]       @relation("RentalEquipmentSupplier")
  requisitions           Requisition[]
  requisitionLines       RequisitionLine[]
  parentSupplier         Supplier?               @relation("SupplierHierarchy", fields: [parentSupplierId], references: [id])
  childSuppliers         Supplier[]              @relation("SupplierHierarchy")
  workOrderResources     WorkOrderResource[]
  inventoryItemSuppliers InventoryItemSupplier[]
  repairHistories        RepairHistory[]
  returns                PurchaseOrderReturn[]
  addresses              SupplierAddress[]
  contacts               SupplierContact[]
  documents              Document[]

  @@index([name])
  @@index([isSupplier])
  @@index([isContractor])
  @@index([parentSupplierId])
  @@index([isActive])
  @@index([rating])
}


model SupplierAddress {
  id                    String    @id @default(cuid())
  supplierId            String
  supplier              Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  addressCode           String    // "MAIN", "PO", "REMIT", etc. - matches Tabware address_code
  label                 String?   // Optional friendly label (e.g., "Main Office", "PO Box")

  // Parsed structured address fields
  address1              String?   // Street address line 1
  address2              String?   // Street address line 2
  city                  String?
  state                 String?
  zip                   String?
  country               String?   @default("USA")

  phone                 String?
  email                 String?

  // Raw address block from Tabware (preserved for reference)
  rawAddress            String?   // The full multi-line text block from Tabware

  // Address type flags (matches Tabware)
  isMailingAddress      Boolean   @default(false)
  isRemittanceAddress   Boolean   @default(false)
  isShippingAddress     Boolean   @default(false)

  // Default flags (matches Tabware)
  isDefaultMailing      Boolean   @default(false)
  isDefaultRemittance   Boolean   @default(false)
  isDefaultShipping     Boolean   @default(false)

  // Metadata
  tabwareLastModified   DateTime? // last_modified from Tabware
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  purchaseOrders        PurchaseOrder[] @relation("POSupplierAddress")

  @@unique([supplierId, addressCode])
  @@index([supplierId])
  @@map("supplier_addresses")
}


model SupplierContact {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  contactType String   // e.g. "REP", "REMITTANCE", "ACCOUNTS_PAYABLE", "PURCHASING", "TECHNICAL", "OTHER"
  name        String
  title       String?
  email       String?
  phone       String?
  phone2      String?  // secondary / mobile
  fax         String?
  notes       String?
  isPrimary   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@index([contactType])
  @@map("supplier_contacts")
}


model RentalEquipment {
  id                 String              @id @default(uuid())
  name               String
  code               String?             @unique
  description        String
  category           String
  specifications     Json?
  defaultSupplierId  String?
  rate               Decimal             @db.Decimal(12, 2)
  unit               RentalUnit          @default(DAY)
  notes              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  defaultSupplier    Supplier?           @relation("RentalEquipmentSupplier", fields: [defaultSupplierId], references: [id])
  workOrderResources WorkOrderResource[]

  @@index([category])
  @@index([isActive])
  @@index([name])
  @@index([defaultSupplierId])
}


enum RentalUnit {
  HOUR
  DAY
  WEEK
  MONTH
  EACH
}
