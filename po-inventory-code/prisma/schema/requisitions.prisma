// Prisma Schema - Requisitions & Approvals


model Requisition {
  id                     String                    @id @default(uuid())
  reqNumber              String                    @unique
  requestedById          String
  supplierId             String?
  status                 String                    @default("Draft")
  neededByDate           DateTime?
  description            String?
  justification          String?
  approvedAt             DateTime?
  approvedBy             String?
  rejectedAt             DateTime?
  rejectionReason        String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  priority               RequisitionPriority       @default(NORMAL)
  submittedAt            DateTime?
  submittedBy            String?
  cancelledAt            DateTime?
  cancelledBy            String?
  convertedToPOAt        DateTime?
  convertedToPOBy        String?
  purchaseOrderId        String?
  purchaseOrderNumber    String?
  isRepairRequisition    Boolean                   @default(false)
  repairableItemId       String?
  requiresApproval       Boolean                   @default(true)
  currentApprovalLevel   Int?
  approvalStatus         RequisitionApprovalStatus @default(DRAFT)
  submittedForApprovalAt DateTime?
  finalApprovedAt        DateTime?
  finalApprovedById      String?
  previousPOIds          String[]                  @default([])
  previousPONumbers      String[]                  @default([])
  resetCount             Int                       @default(0)
  lastResetAt            DateTime?
  lastResetReason        String?

  // ─── Tax Module ────────────────────────────────────────────────────────────
  // taxAmount: Estimated tax on this requisition. Only populated when the tax
  // module is enabled in FinanceSettings. Defaults to 0; carried into PO on
  // conversion. Stored for accurate budget commitment amounts.
  taxAmount      Decimal @default(0) @db.Decimal(18, 6)

  // ─── Purchasing Manager Assignment ────────────────────────────────────────
  // Only populated when FinanceSettings.buyerAssignmentEnabled = true.
  // Stores the User.id of the Purchasing Manager assigned to this requisition.
  // Plain UUID — no FK relation (avoids cascading changes to the User model).
  // When the flag is OFF (default) this column is always null. Zero risk to
  // existing source code clients that do not use the buyer assignment feature.
  assignedBuyerId  String?  @map("assigned_buyer_id")

  // COMPUTED FIELDS FOR LINE-LEVEL TRACKING
  totalLines     Int @default(0)
  orderedLines   Int @default(0)
  pendingLines   Int @default(0)
  fulfilledLines Int @default(0)
  approvedLines  Int @default(0)
  cancelledLines Int @default(0)

  // Relations
  documents          Document[]
  finalApprovedBy    User?                       @relation("RequisitionFinalApprover", fields: [finalApprovedById], references: [id])
  repairableItem     RepairableItem?             @relation(fields: [repairableItemId], references: [id])
  requestedBy        User                        @relation(fields: [requestedById], references: [id])
  supplier           Supplier?                   @relation(fields: [supplierId], references: [id])
  approvals          RequisitionApproval[]
  lines              RequisitionLine[]
  workOrderResources WorkOrderResource[]
  repairHistories    RepairHistory[]
  budgetHeader       RequisitionBudgetHeader?
  lineAllocations    RequisitionLineAllocation[]
  poLines            POLine[]

  @@index([reqNumber])
  @@index([requestedById])
  @@index([supplierId])
  @@index([status])
  @@index([status, createdAt])
  @@index([requestedById, status])
  @@index([purchaseOrderId])
  @@index([isRepairRequisition])
  @@index([repairableItemId])
  @@index([approvalStatus])
  @@index([currentApprovalLevel])
  // Composite index for statistics queries (optimizes date range + status filtering)
  @@index([createdAt, status, requestedById])
  @@index([approvedAt])
  @@index([submittedForApprovalAt])
  @@index([resetCount])
  @@index([lastResetAt])
  // NEW INDEXES FOR COMPUTED FIELDS
  @@index([totalLines])
  @@index([orderedLines])
  @@index([pendingLines])
  @@index([assignedBuyerId])
}


model RequisitionLine {
  id              String       @id @default(uuid())
  requisitionId   String
  inventoryItemId String?
  supplierId      String?
  description     String
  quantity        Decimal      @db.Decimal(10, 2)
  unit            String       @default("EA")
  estimatedPrice  Decimal      @db.Decimal(18, 6)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lineType        LineItemType

  // LINE-LEVEL TRACKING FIELDS
  lineStatus          RequisitionLineStatus @default(PENDING)
  purchaseOrderId     String?
  purchaseOrderNumber String?
  poLineId            String?
  convertedToPOAt     DateTime?
  convertedToPOBy     String?

  // Service/Consumable fields
  consumableCategory  String?
  contractNumber      String?
  deliverables        String?
  estimatedHours      Decimal?  @db.Decimal(8, 2)
  expirationTracking  Boolean   @default(false)
  hourlyRate          Decimal?  @db.Decimal(12, 2)
  manufacturer        String?
  modelNumber         String?
  monthlyUsageRate    Decimal?  @db.Decimal(10, 2)
  packageSize         String?
  sdsRequired         Boolean   @default(false)
  serviceEndDate      DateTime?
  serviceEquipmentId  String?
  serviceLocation     String?
  serviceProvider     String?
  serviceStartDate    DateTime?
  serviceType         String?
  serviceWorkOrderId  String?
  slaDetails          String?
  storageRequirements String?

  // Relations
  inventoryItem InventoryItem?              @relation(fields: [inventoryItemId], references: [id])
  requisition   Requisition                 @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  supplier      Supplier?                   @relation(fields: [supplierId], references: [id])
  allocations   RequisitionLineAllocation[]

  // NEW RELATIONS FOR LINE-LEVEL TRACKING
  purchaseOrder   PurchaseOrder? @relation("RequisitionLinePO", fields: [purchaseOrderId], references: [id])
  poLine          POLine?        @relation("RequisitionLinePOLine", fields: [poLineId], references: [id])
  convertedByUser User?          @relation("RequisitionLineConverter", fields: [convertedToPOBy], references: [id])

  @@index([inventoryItemId])
  @@index([requisitionId])
  @@index([supplierId])
  @@index([lineType])
  @@index([serviceType])
  @@index([consumableCategory])
  // NEW INDEXES FOR LINE-LEVEL TRACKING
  @@index([lineStatus])
  @@index([purchaseOrderId])
  @@index([poLineId])
  @@index([convertedToPOAt])
  @@index([convertedToPOBy])
}


model ApprovalSettings {
  id                         String   @id @default(uuid())
  globalAutoApproveThreshold Decimal  @default(0) @db.Decimal(15, 2)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  updatedBy                  String?

  @@map("approval_settings")
}


model RequisitionApprovalLevel {
  id                   String                  @id @default(uuid())
  level                Int                     @unique
  name                 String
  levelType            ApprovalLevelType
  minAmount            Decimal                 @db.Decimal(15, 2)
  maxAmount            Decimal?                @db.Decimal(15, 2)
  description          String?
  isActive             Boolean                 @default(true)
  requiresAllApprovers Boolean                 @default(false)
  autoApproveThreshold Decimal?                @db.Decimal(15, 2)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  approvals            RequisitionApproval[]
  userAuthorities      UserApprovalAuthority[]

  @@index([level])
  @@index([isActive])
}


model RequisitionApproval {
  id               String                    @id @default(uuid())
  requisitionId    String
  approvalLevelId  String
  levelNumber      Int
  approverId       String
  action           ApprovalAction
  status           RequisitionApprovalStatus
  comments         String?
  attachments      Json?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  delegatedAt      DateTime?
  delegatedToId    String?
  delegationReason String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  approvalLevel    RequisitionApprovalLevel  @relation(fields: [approvalLevelId], references: [id])
  approver         User                      @relation("RequisitionApprover", fields: [approverId], references: [id])
  delegatedTo      User?                     @relation("RequisitionApprovalDelegate", fields: [delegatedToId], references: [id])
  requisition      Requisition               @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@unique([requisitionId, approvalLevelId, approverId])
  @@index([requisitionId])
  @@index([approverId])
  @@index([status])
  @@index([action])
  @@index([approvedAt])
}


model UserApprovalAuthority {
  id                  String                   @id @default(uuid())
  userId              String
  approvalLevelId     String
  maxAmount           Decimal                  @db.Decimal(15, 2)
  isActive            Boolean                  @default(true)
  isPrimary           Boolean                  @default(false)
  canDelegate         Boolean                  @default(true)
  delegatedFromId     String?
  delegationStartDate DateTime?
  delegationEndDate   DateTime?
  grantedById         String
  grantedAt           DateTime                 @default(now())
  revokedById         String?
  revokedAt           DateTime?
  revocationReason    String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  approvalLevel       RequisitionApprovalLevel @relation(fields: [approvalLevelId], references: [id])
  delegatedFrom       User?                    @relation("DelegatedAuthorities", fields: [delegatedFromId], references: [id])
  grantedBy           User                     @relation("GrantedAuthorities", fields: [grantedById], references: [id])
  revokedBy           User?                    @relation("RevokedAuthorities", fields: [revokedById], references: [id])
  user                User                     @relation("UserApprovalAuthorities", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, approvalLevelId])
  @@index([userId])
  @@index([approvalLevelId])
  @@index([isActive])
  @@index([delegationEndDate])
}


enum RequisitionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}


enum RequisitionType {
  CHARGE_TO_ACCOUNT
  CHARGE_TO_WORK_ORDER
  CHARGE_TO_PROJECT
  ADD_TO_REORDER
}


enum RequisitionLineStatus {
  PENDING
  APPROVED
  ORDERED
  CANCELLED
  FULFILLED
  PARTIALLY_FULFILLED
}


enum RequisitionApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  PARTIALLY_APPROVED
  ORDERED
  FULFILLED
  PARTIALLY_FULFILLED
}


enum ApprovalAction {
  APPROVE
  REJECT
  DELEGATE
  REQUEST_CHANGES
}


enum ApprovalLevelType {
  AUTO_APPROVE
  SUPERVISOR
  MANAGER
  EXECUTIVE
  BOARD
}
