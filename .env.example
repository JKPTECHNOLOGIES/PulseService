# Copy this file to .env and adjust values before running `docker compose up`.
# These variables are consumed by docker-compose.yml.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Credentials for the bundled `db` (postgres:16-alpine) service.
POSTGRES_USER=pulseservice
POSTGRES_PASSWORD=pulseservice
POSTGRES_DB=pulseservice

# Connection string the backend uses to reach Postgres. The host `db` is the
# compose service name. Change credentials here if you change them above.
DATABASE_URL=postgresql://pulseservice:pulseservice@db:5432/pulseservice?schema=public

# ── Backend ───────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=pulseservice-super-secret-jwt-key-change-in-production

# JWT lifetime
JWT_EXPIRES_IN=7d

# Public URL the frontend is served from (used for CORS on the backend).
FRONTEND_URL=http://localhost:8080
